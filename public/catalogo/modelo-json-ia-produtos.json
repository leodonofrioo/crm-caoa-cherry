{
  "tipo": "modelo_json_para_ia_criar_produtos_crm_thayna_reis",
  "versao_modelo": 1,
  "objetivo": "Use este modelo para treinar uma IA a gerar JSON de produtos, variacoes e compatibilidades no formato aceito pelo CRM.",
  "formato_de_importacao_do_crm": {
    "schema": "crm-thayna-reis-export",
    "version": 1,
    "exportedAt": "2026-06-18T00:00:00.000Z",
    "source": "CRM Thayná Reis",
    "sections": ["products"],
    "data": {
      "products": []
    }
  },
  "modelos_permitidos": ["Tiggo 5", "Tiggo 7", "Tiggo 8"],
  "categorias_permitidas": [
    "Película Solar",
    "Película",
    "Tapete",
    "Proteção",
    "Segurança",
    "Estética",
    "Tecnologia",
    "Iluminação",
    "Serviço",
    "Outro"
  ],
  "instrucoes_gerais_para_ia": [
    "A resposta final da IA deve ser JSON valido, sem markdown, sem comentarios e sem texto fora do JSON.",
    "Use sempre o formato de importacao do CRM: schema, version, exportedAt, source, sections e data.products.",
    "Para importar somente produtos, sections deve ser [\"products\"].",
    "Cada produto deve ter id unico e estavel, name, description, category, compatibilities, universal, active e variations.",
    "Cada variacao deve ter id unico e estavel, name, description, price, timeEstimate, compatibilities e active.",
    "price deve ser numero em reais, sem R$, sem ponto de milhar e sem string. Exemplo: 1250.",
    "timeEstimate deve ser numero inteiro em minutos. Exemplo: 90.",
    "active deve ser true para item disponivel e false para item desativado.",
    "imageUrl pode ser string vazia ou omitido quando nao existir imagem.",
    "attributes pode guardar codigo, sku, transparencia, uvProtection, heatRejection, infraredRejection e outros dados tecnicos.",
    "Nunca use nomes de modelos fora de: Tiggo 5, Tiggo 7, Tiggo 8.",
    "Nunca use textos como TODOS, QUALQUER, ALL ou GERAL dentro de compatibilities. Use as regras estruturadas abaixo.",
    "Se um produto tiver variacoes com compatibilidades diferentes, cada variacao deve ter sua propria lista de compatibilities.",
    "product.compatibilities deve ser a uniao das compatibilidades das variacoes, exceto quando universal for true."
  ],
  "regras_de_compatibilidade": {
    "compativel_com_todos_os_modelos_versoes_e_anos": {
      "quando_usar": "Quando o produto serve para Tiggo 5, Tiggo 7, Tiggo 8, todas as versoes e todos os anos.",
      "como_preencher": {
        "product.universal": true,
        "product.compatibilities": [],
        "variation.compatibilities": []
      }
    },
    "compativel_com_todos_os_anos_e_versoes_de_um_modelo": {
      "quando_usar": "Quando serve para todas as versoes e anos de um modelo especifico.",
      "exemplo": {
        "universal": false,
        "compatibilities": [
          {
            "model": "Tiggo 7"
          }
        ]
      }
    },
    "compativel_com_uma_versao_de_um_modelo_em_todos_os_anos": {
      "quando_usar": "Quando serve para uma versao especifica, mas em qualquer ano dessa versao.",
      "exemplo": {
        "universal": false,
        "compatibilities": [
          {
            "model": "Tiggo 7",
            "version": "PRO HYBRID MAX DRIVE"
          }
        ]
      }
    },
    "compativel_com_um_modelo_em_um_ano_especifico": {
      "quando_usar": "Quando serve para qualquer versao de um modelo, mas somente em um ano especifico.",
      "exemplo": {
        "universal": false,
        "compatibilities": [
          {
            "model": "Tiggo 8",
            "year": "2025"
          }
        ]
      }
    },
    "compativel_com_uma_versao_em_um_ano_especifico": {
      "quando_usar": "Quando serve somente para uma versao e um ano exatos.",
      "exemplo": {
        "universal": false,
        "compatibilities": [
          {
            "model": "Tiggo 5",
            "version": "PRO",
            "year": "2026"
          }
        ]
      }
    },
    "compativel_com_multiplos_modelos_ou_multiplas_versoes": {
      "quando_usar": "Quando serve para mais de um modelo, versao ou ano especifico.",
      "exemplo": {
        "universal": false,
        "compatibilities": [
          {
            "model": "Tiggo 5"
          },
          {
            "model": "Tiggo 7",
            "version": "SPORT",
            "year": "2025"
          },
          {
            "model": "Tiggo 8",
            "version": "PRO PLUG-IN HYBRID"
          }
        ]
      }
    }
  },
