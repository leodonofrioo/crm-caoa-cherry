# DATABASE_URL: PostgreSQL connection used by Prisma on server/Coolify.
DATABASE_URL="COOLIFY_POSTGRES_CONNECTION_URL"

# CRM_AUTH_LOGIN / CRM_AUTH_PASSWORD_HASH: private CRM login.
# Do not prefix with VITE_; otherwise value is exposed in frontend bundle.
CRM_AUTH_LOGIN="change-me"
CRM_AUTH_PASSWORD_HASH="bcrypt-hash-from-npm-run-auth-hash"
CRM_AUTH_SESSION_SECRET="change-me-random-secret"
CRM_AUTH_DISPLAY_NAME="Thayná Reis"
COOKIE_SECURE="true"
APP_BASE_URL="https://seu-dominio.com"
PORT="3000"
